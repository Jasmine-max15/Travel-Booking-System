db = connect_db()
cursor = db.cursor()
def add_customer():
    name = input("Enter name: ")
    email = input("Enter email: ")

    try:
        cursor.execute(
            "INSERT INTO Customers (name, email) VALUES (%s, %s)",
            (name, email))
        db.commit()
        print("✅ Customer added!")
    except Exception as e:
        print("❌ Error:", e)
def add_package():
    destination = input("Enter destination: ")
    price = int(input("Enter price: "))
    try:
        cursor.execute(
            "INSERT INTO Packages (destination, price) VALUES (%s, %s)",
            (destination, price))
        db.commit()
        print("✅ Package added!")
    except Exception as e:
        print("❌ Error:", e)
def book_trip():
    cid = int(input("Enter Customer ID: "))
    pid = int(input("Enter Package ID: "))
    date = input("Enter travel date (YYYY-MM-DD): ")
    try:
        cursor.execute(
            "INSERT INTO Bookings (customer_id, package_id, travel_date) VALUES (%s, %s, %s)",
            (cid, pid, date))
        db.commit()
        print("✅ Booking successful!")
    except Exception as e:
        print("❌ Error:", e)

def view_bookings():
    cursor.execute("""
        SELECT Customers.name, Packages.destination, Packages.price, Bookings.travel_date
        FROM Bookings
        JOIN Customers ON Bookings.customer_id = Customers.customer_id
        JOIN Packages ON Bookings.package_id = Packages.package_id
    """)
    data = cursor.fetchall()
    if not data:
        print("⚠️ No bookings found")
    else:
        print("\n📌 Bookings:")
        for row in data:
            print(f"Customer: {row[0]} | Destination: {row[1]} | Price: {row[2]} | Date: {row[3]}")
def menu():
